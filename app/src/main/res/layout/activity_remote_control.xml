<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_premium_gradient"
    android:padding="24dp">

    <TextView
        android:id="@+id/headerLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_panel_soft"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:text="REMOTE CONTROL"
        android:textAllCaps="true"
        android:textColor="@color/accent_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.2"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/glass_surface"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLabel"
        app:strokeColor="@color/glass_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Searching for Prompter..."
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_glass_panel_soft"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="PRO LIVE CONTROL"
                android:textAllCaps="true"
                android:textColor="@color/accent_warm"
                android:textSize="11sp"
                android:letterSpacing="0.18"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Use your phone as the control deck while the prompt runs on a larger screen."
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/controller_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_rc_play_pause"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:backgroundTint="@color/accent_primary"
                    android:text="Play / Pause"
                    android:textColor="@color/midnight_900"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_rc_slower"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="@android:color/transparent"
                        android:text="Slower"
                        android:textColor="@color/text_primary"
                        app:strokeColor="@color/glass_stroke" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_rc_faster"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="@android:color/transparent"
                        android:text="Faster"
                        android:textColor="@color/text_primary"
                        app:strokeColor="@color/glass_stroke" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_rc_reset"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@android:color/transparent"
                    android:text="Reset Scroll"
                    android:textColor="@color/danger_soft"
                    app:strokeColor="@color/glass_stroke" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
