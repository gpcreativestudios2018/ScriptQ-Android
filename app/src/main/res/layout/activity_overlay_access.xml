<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_premium_gradient"
    android:orientation="vertical"
    android:padding="20dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_glass_panel"
        app:navigationIconTint="@color/text_primary"
        app:title="Overlay Access"
        app:titleTextColor="@color/text_primary" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="@android:color/transparent"
        android:background="@drawable/bg_glass_panel_overlay"
        app:cardCornerRadius="30dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/glass_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/textStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Overlay access is off."
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="2dp"
                android:text="ScriptQ needs Android's Display over other apps permission to float the teleprompter over Camera, Meet, or any other app."
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="What to do"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/buttonOverlayInfo"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_glass_panel_overlay_soft"
                    android:contentDescription="Overlay help"
                    android:padding="7dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="@color/text_primary" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:text="1. Tap Open Android overlay settings.\n2. In the list, choose ScriptQ.\n3. Turn on Allow display over other apps.\n4. Come back here and tap Check again."
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOpenSettings"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:text="Open Android overlay settings"
                android:textAllCaps="false"
                android:textColor="@color/midnight_900"
                app:backgroundTint="@color/accent_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCheckAgain"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Check again"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                app:strokeColor="@color/glass_stroke" />

            <TextView
                android:id="@+id/textInlineStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="2dp"
                android:text="If Android opens a generic list instead of ScriptQ directly, choose ScriptQ manually from that list."
                android:textColor="@color/text_tertiary"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
