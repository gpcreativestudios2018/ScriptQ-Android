<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ScriptQ" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorSurface">@color/midnight_800</item>
        <item name="colorSurfaceVariant">@color/glass_surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnPrimary">@color/midnight_900</item>
        <item name="colorError">@color/danger_soft</item>
        <item name="android:windowBackground">@drawable/bg_premium_gradient</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="materialCardViewStyle">@style/Widget.ScriptQ.GlassCard</item>
    </style>

    <style name="ThemeOverlay.ScriptQ.PopupMenu" parent="ThemeOverlay.Material3.Dark">
        <item name="android:popupBackground">@drawable/bg_popup_glass</item>
        <item name="popupMenuStyle">@style/Widget.ScriptQ.PopupMenu</item>
        <item name="listPopupWindowStyle">@style/Widget.ScriptQ.ListPopupWindow</item>
        <item name="textAppearanceLargePopupMenu">@style/TextAppearance.ScriptQ.PopupMenu</item>
        <item name="textAppearanceSmallPopupMenu">@style/TextAppearance.ScriptQ.PopupMenu</item>
    </style>

    <style name="Widget.ScriptQ.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_glass</item>
    </style>

    <style name="Widget.ScriptQ.ListPopupWindow" parent="Widget.AppCompat.ListPopupWindow">
        <item name="android:popupBackground">@drawable/bg_popup_glass</item>
    </style>

    <style name="TextAppearance.ScriptQ.PopupMenu" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.ScriptQ.GlassCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="strokeColor">@color/glass_stroke_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/midnight_900</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.ScriptQ</item>
    </style>
</resources>
